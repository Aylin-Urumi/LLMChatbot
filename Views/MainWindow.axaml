<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:LLMChatbot"
        xmlns:vm="using:LLMChatbot.ViewModels"
        x:Class="LLMChatbot.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="LLM Chatbot"
        Width="700" Height="700"
        Background="#716767">

  <Grid RowDefinitions="*, Auto" Margin="16">

    <!-- Chat messages list -->
    <ScrollViewer Grid.Row="0" Name="ScrollViewer">
      <ItemsControl ItemsSource="{Binding Messages}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="local:Message">
            <StackPanel Margin="4,6" Spacing="4">
              <Border Padding="12,8"
                      CornerRadius="12"
                      HorizontalAlignment="{Binding Role, 
                        Converter={StaticResource RoleToAlignmentConverter}}"
                      Background="{Binding Role, 
                        Converter={StaticResource RoleToColorConverter}}">
                <TextBlock Text="{Binding Content}"
                           Foreground="White"
                           TextWrapping="Wrap"
                           MaxWidth="400"/>
              </Border>
              <TextBlock Text="{Binding Timestamp, Converter={StaticResource TimestampConverter}}"
                         Foreground="#999999"
                         FontSize="11"
                         Margin="12,0,0,0"
                         HorizontalAlignment="{Binding Role, 
                           Converter={StaticResource RoleToAlignmentConverter}}"/>
            </StackPanel>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <!-- Input area -->
    <Grid Grid.Row="1" ColumnDefinitions="*, Auto, Auto, Auto" Margin="0,8,0,0">

      <TextBox Grid.Column="0"
               Text="{Binding UserInput}"
               Watermark="Type a message..."
               CornerRadius="20"
               Padding="16,10"
               Margin="0,0,8,0"/>

      <Button Grid.Column="1"
              Content="Send"
              IsEnabled="{Binding !IsBusy}"
              Click="OnSendClicked"
              CornerRadius="20"
              Padding="20,10"
              Background="#6750A4"
              Foreground="White"/>

      <Button Grid.Column="2"
              Content="Save"
              Click="OnSaveClicked"
              CornerRadius="20"
              Padding="20,10"
              Background="#4CAF50"
              Foreground="White"/>

      <Button Grid.Column="3"
              Content="Clear"
              Click="OnClearClicked"
              CornerRadius="20"
              Padding="20,10"
              Background="#D32F2F"
              Foreground="White"/>
          
    </Grid>

  </Grid>
</Window>